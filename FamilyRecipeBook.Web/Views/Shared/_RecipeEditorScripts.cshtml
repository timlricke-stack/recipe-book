<script>
(function () {
    // --- Ingredients ---
    var ingredientsList = document.getElementById('ingredients-list');
    var addIngredientBtn = document.getElementById('add-ingredient');

    function ingredientIndex() {
        return ingredientsList.querySelectorAll('.ingredient-row').length;
    }

    function createIngredientRow(idx) {
        var row = document.createElement('div');
        row.className = 'ingredient-row row g-2 mb-2 align-items-center';

        function makeCol(cls, child) {
            var col = document.createElement('div');
            col.className = cls;
            col.appendChild(child);
            return col;
        }

        function makeInput(type, name, placeholder) {
            var inp = document.createElement('input');
            inp.type = type;
            inp.name = name;
            inp.className = 'form-control form-control-sm';
            inp.placeholder = placeholder;
            if (type === 'number') { inp.step = '0.01'; inp.min = '0'; }
            return inp;
        }

        var qtyInput = makeInput('number', 'Ingredients[' + idx + '].Quantity', 'Qty');
        var unitInput = makeInput('text', 'Ingredients[' + idx + '].Unit', 'Unit');
        var nameInput = makeInput('text', 'Ingredients[' + idx + '].IngredientName', 'Ingredient *');
        nameInput.required = true;
        var noteInput = makeInput('text', 'Ingredients[' + idx + '].PrepNote', 'Prep note');

        var removeBtn = document.createElement('button');
        removeBtn.type = 'button';
        removeBtn.className = 'btn btn-sm btn-outline-danger remove-row';
        removeBtn.setAttribute('aria-label', 'Remove ingredient');
        removeBtn.textContent = '\u00d7';

        row.appendChild(makeCol('col-3 col-md-2', qtyInput));
        row.appendChild(makeCol('col-3 col-md-2', unitInput));
        row.appendChild(makeCol('col-12 col-md-4', nameInput));
        row.appendChild(makeCol('col-9 col-md-3', noteInput));
        var btnCol = document.createElement('div');
        btnCol.className = 'col-3 col-md-1 d-flex justify-content-end';
        btnCol.appendChild(removeBtn);
        row.appendChild(btnCol);

        return row;
    }

    function reindexIngredients() {
        var rows = ingredientsList.querySelectorAll('.ingredient-row');
        rows.forEach(function (row, i) {
            row.querySelectorAll('input').forEach(function (inp) {
                inp.name = inp.name.replace(/Ingredients\[\d+\]/, 'Ingredients[' + i + ']');
            });
        });
    }

    addIngredientBtn.addEventListener('click', function () {
        ingredientsList.appendChild(createIngredientRow(ingredientIndex()));
    });

    ingredientsList.addEventListener('click', function (e) {
        if (e.target.classList.contains('remove-row')) {
            e.target.closest('.ingredient-row').remove();
            reindexIngredients();
        }
    });

    // --- Steps ---
    var stepsList = document.getElementById('steps-list');
    var addStepBtn = document.getElementById('add-step');

    function stepIndex() {
        return stepsList.querySelectorAll('.step-row').length;
    }

    function createStepRow(idx) {
        var row = document.createElement('div');
        row.className = 'step-row row g-2 mb-2 align-items-start';

        var numDiv = document.createElement('div');
        numDiv.className = 'col-auto pt-2 text-muted step-number fw-bold';
        numDiv.textContent = (idx + 1) + '.';

        var ta = document.createElement('textarea');
        ta.name = 'Steps[' + idx + '].InstructionText';
        ta.className = 'form-control form-control-sm';
        ta.rows = 2;
        ta.placeholder = 'Describe this step...';

        var taCol = document.createElement('div');
        taCol.className = 'col';
        taCol.appendChild(ta);

        var removeBtn = document.createElement('button');
        removeBtn.type = 'button';
        removeBtn.className = 'btn btn-sm btn-outline-danger remove-row';
        removeBtn.setAttribute('aria-label', 'Remove step');
        removeBtn.textContent = '\u00d7';

        var btnCol = document.createElement('div');
        btnCol.className = 'col-auto';
        btnCol.appendChild(removeBtn);

        row.appendChild(numDiv);
        row.appendChild(taCol);
        row.appendChild(btnCol);
        return row;
    }

    function reindexSteps() {
        var rows = stepsList.querySelectorAll('.step-row');
        rows.forEach(function (row, i) {
            var num = row.querySelector('.step-number');
            if (num) num.textContent = (i + 1) + '.';
            var ta = row.querySelector('textarea');
            if (ta) ta.name = 'Steps[' + i + '].InstructionText';
        });
    }

    addStepBtn.addEventListener('click', function () {
        stepsList.appendChild(createStepRow(stepIndex()));
    });

    stepsList.addEventListener('click', function (e) {
        if (e.target.classList.contains('remove-row')) {
            e.target.closest('.step-row').remove();
            reindexSteps();
        }
    });
}());
</script>
