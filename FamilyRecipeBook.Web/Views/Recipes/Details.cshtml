@model FamilyRecipeBook.Web.Models.RecipeDetailViewModel

@{
    ViewData["Title"] = Model.Title;
}

<section class="hero-splash mb-4">
    <div class="d-flex flex-column flex-lg-row justify-content-between gap-3">
        <div>
            <h1 class="display-6 mb-2">@Model.Title</h1>
            @if (!string.IsNullOrWhiteSpace(Model.Description))
            {
                <p class="mb-2">@Model.Description</p>
            }
            <div class="meta-row">
                <span>@Model.TotalMinutes min total</span>
                <span>Prep @Model.PrepMinutes</span>
                <span>Cook @Model.CookMinutes</span>
                @if (Model.Servings.HasValue)
                {
                    <span>Serves @Model.Servings</span>
                }
                @if (Model.IsFavorite)
                {
                    <span class="badge favorite-badge">Favorite</span>
                }
            </div>
            @if (!string.IsNullOrWhiteSpace(Model.SubmittedBy))
            {
                <p class="mb-0 mt-2 small">Submitted by <strong>@Model.SubmittedBy</strong></p>
            }
            @if (!string.IsNullOrWhiteSpace(Model.Source))
            {
                <p class="mb-0 small">Source: <em>@Model.Source</em></p>
            }
        </div>
        <div class="d-flex align-items-start gap-2 flex-wrap">
            <a class="btn btn-outline-light" asp-controller="Recipes" asp-action="Edit" asp-route-id="@Model.RecipeId">Edit</a>
            <a class="btn btn-outline-light" asp-controller="Recipes" asp-action="Index">Back to recipes</a>
            <form asp-action="Delete" asp-route-id="@Model.RecipeId" method="post"
                  onsubmit="return confirm('Delete this recipe? This cannot be undone.');">
                <button type="submit" class="btn btn-danger">Delete</button>
            </form>
        </div>
    </div>
</section>

<div class="row g-4">
    <div class="col-12 col-lg-5">
        <section class="recipe-card h-100">
            <h2 class="h5">Ingredients</h2>
            @if (Model.Ingredients.Count == 0)
            {
                <p class="text-muted mb-0">No ingredients listed yet.</p>
            }
            else
            {
                <ol class="ps-3 mb-0">
                    @foreach (var ingredient in Model.Ingredients)
                    {
                        <li class="mb-2">
                            @if (ingredient.Quantity.HasValue)
                            {
                                <span>@ingredient.Quantity</span>
                            }
                            @if (!string.IsNullOrWhiteSpace(ingredient.Unit))
                            {
                                <span> @ingredient.Unit</span>
                            }
                            <span> @ingredient.IngredientName</span>
                            @if (!string.IsNullOrWhiteSpace(ingredient.PrepNote))
                            {
                                <span class="text-muted"> (@ingredient.PrepNote)</span>
                            }
                        </li>
                    }
                </ol>
            }
        </section>
    </div>

    <div class="col-12 col-lg-7">
        <section class="recipe-card h-100">
            <h2 class="h5">Directions</h2>
            @if (Model.Steps.Count == 0)
            {
                <p class="text-muted mb-0">No steps listed yet.</p>
            }
            else
            {
                <ol class="ps-3 mb-0">
                    @foreach (var step in Model.Steps)
                    {
                        <li class="mb-2">@step.InstructionText</li>
                    }
                </ol>
            }
        </section>
    </div>
</div>
