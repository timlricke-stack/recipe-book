      "steps": [
        {
          "stepNumber": 1,
          "instructionText": "Whisk dry ingredients in a large bowl."
        },
        {
          "stepNumber": 2,
          "instructionText": "Stir in milk, egg, melted butter, and vanilla until just combined."
        },
        {
          "stepNumber": 3,
          "instructionText": "Heat a lightly buttered skillet over medium heat."
