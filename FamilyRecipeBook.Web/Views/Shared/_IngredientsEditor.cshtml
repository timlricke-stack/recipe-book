@model FamilyRecipeBook.Web.Models.CreateRecipeInputModel

<div class="col-12 mt-3">
    <h5 class="mb-2">Ingredients</h5>
    <div id="ingredients-list">
        @for (int i = 0; i < Model.Ingredients.Count; i++)
        {
            <div class="ingredient-row row g-2 mb-2 align-items-center">
                <div class="col-3 col-md-2">
                    <input name="Ingredients[@i].Quantity" value="@Model.Ingredients[i].Quantity" type="number" step="0.01" min="0" class="form-control form-control-sm" placeholder="Qty" />
                </div>
                <div class="col-3 col-md-2">
                    <input name="Ingredients[@i].Unit" value="@Model.Ingredients[i].Unit" type="text" class="form-control form-control-sm" placeholder="Unit" />
                </div>
                <div class="col-12 col-md-4">
                    <input name="Ingredients[@i].IngredientName" value="@Model.Ingredients[i].IngredientName" type="text" class="form-control form-control-sm" placeholder="Ingredient *" required />
                </div>
                <div class="col-9 col-md-3">
                    <input name="Ingredients[@i].PrepNote" value="@Model.Ingredients[i].PrepNote" type="text" class="form-control form-control-sm" placeholder="Prep note" />
                </div>
                <div class="col-3 col-md-1 d-flex justify-content-end">
                    <button type="button" class="btn btn-sm btn-outline-danger remove-row" aria-label="Remove ingredient">&times;</button>
                </div>
            </div>
        }
    </div>
    <button type="button" id="add-ingredient" class="btn btn-sm btn-outline-secondary mt-1">+ Add Ingredient</button>
    <div class="form-text">Quantity and unit are optional. Ingredient name is required for each row you add.</div>
</div>
