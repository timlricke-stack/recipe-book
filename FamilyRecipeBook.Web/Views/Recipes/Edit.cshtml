@model FamilyRecipeBook.Web.Models.CreateRecipeInputModel

@{
    var recipeId = (int)ViewData["RecipeId"]!;
    ViewData["Title"] = "Edit Recipe";
}

<section class="hero-splash mb-4">
    <h1 class="display-6 mb-1">Edit Recipe</h1>
    <p class="mb-0">Update the details, ingredients, and steps.</p>
</section>

<section class="recipe-card">
    <form asp-action="Edit" asp-route-id="@recipeId" method="post" class="row g-3">
        <div asp-validation-summary="ModelOnly" class="text-danger"></div>

        <div class="col-12 col-md-8">
            <label asp-for="Title" class="form-label"></label>
            <input asp-for="Title" class="form-control" />
            <span asp-validation-for="Title" class="text-danger"></span>
        </div>

        <div class="col-12 col-md-4">
            <label asp-for="SubmittedBy" class="form-label"></label>
            <input asp-for="SubmittedBy" class="form-control" placeholder="e.g. Grandma Rose" />
            <span asp-validation-for="SubmittedBy" class="text-danger"></span>
        </div>

        <div class="col-12">
            <label asp-for="Description" class="form-label"></label>
            <textarea asp-for="Description" class="form-control" rows="3"></textarea>
            <span asp-validation-for="Description" class="text-danger"></span>
        </div>

        <div class="col-6 col-md-3">
            <label asp-for="PrepMinutes" class="form-label"></label>
            <input asp-for="PrepMinutes" class="form-control" />
            <span asp-validation-for="PrepMinutes" class="text-danger"></span>
        </div>

        <div class="col-6 col-md-3">
            <label asp-for="CookMinutes" class="form-label"></label>
            <input asp-for="CookMinutes" class="form-control" />
            <span asp-validation-for="CookMinutes" class="text-danger"></span>
        </div>

        <div class="col-6 col-md-3">
            <label asp-for="Servings" class="form-label"></label>
            <input asp-for="Servings" class="form-control" />
            <span asp-validation-for="Servings" class="text-danger"></span>
        </div>

        <div class="col-6 col-md-3">
            <label asp-for="Source" class="form-label"></label>
            <input asp-for="Source" class="form-control" placeholder="e.g. Family Card Box" />
            <span asp-validation-for="Source" class="text-danger"></span>
        </div>

        <div class="col-12">
            <div class="form-check">
                <input asp-for="IsFavorite" class="form-check-input" />
                <label asp-for="IsFavorite" class="form-check-label"></label>
            </div>
        </div>

        @await Html.PartialAsync("_IngredientsEditor", Model)

        @await Html.PartialAsync("_StepsEditor", Model)

        <div class="col-12 d-flex gap-2">
            <button type="submit" class="btn btn-accent">Save Changes</button>
            <a asp-controller="Recipes" asp-action="Details" asp-route-id="@recipeId" class="btn btn-outline-secondary">Cancel</a>
        </div>
    </form>
</section>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <partial name="_RecipeEditorScripts" />
}
